{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TodoList",
  "description": "ToDoアイテムのリストを管理するためのスキーマ",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "title",
      "status",
      "created_at"
    ],
    "properties": {
      "id": {
        "type": "string",
        "format": "uuid",
        "description": "ToDoアイテムの一意の識別子（UUIDなどを想定）"
      },
      "title": {
        "type": "string",
        "minLength": 1,
        "description": "ToDoのタイトルまたはタスク名"
      },
      "description": {
        "type": "string",
        "description": "ToDoの詳細な説明"
      },
      "status": {
        "type": "string",
        "enum": [
          "todo",
          "in_progress",
          "done"
        ],
        "default": "todo",
        "description": "タスクの現在の進捗ステータス"
      },
      "priority": {
        "type": "string",
        "enum": [
          "low",
          "medium",
          "high"
        ],
        "default": "medium",
        "description": "タスクの優先度"
      },
      "created_at": {
        "type": "string",
        "format": "date-time",
        "description": "タスクの作成日時（ISO 8601形式）"
      },
      "updated_at": {
        "type": "string",
        "format": "date-time",
        "description": "タスクの最終更新日時（ISO 8601形式）"
      },
      "end_date": {
        "type": "string",
        "format": "date",
        "description": "タスクの終了日（YYYY-MM-DD形式）"
      },
      "start_date": {
        "type": "string",
        "format": "date",
        "description": "タスクの開始日（YYYY-MM-DD形式）"
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "uniqueItems": true,
        "description": "タスクに関連付けられたタグのリスト"
      },
      "dependencies": {
        "type": "array",
        "items": {
          "type": "string",
          "format": "uuid"
        },
        "uniqueItems": true,
        "description": "このタスクを開始する前に完了していなければならない前提タスクのID（UUID）リスト"
      },
      "assignees": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "タスクの担当者リスト"
      }
    },
    "additionalProperties": false
  }
}